---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { href: '/', label: 'Home', code: '00' },
  { href: '/services', label: 'Services', code: '01' },
  { href: '/work', label: 'Work', code: '02' },
  { href: '/about', label: 'About', code: '03' },
  { href: '/contact', label: 'Contact', code: '04' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const buildId = new Date().toISOString().slice(0, 10);
---

<header class="masthead" transition:persist="masthead">
  <div class="bar top-bar mono">
    <span class="bar-cell">CUKO·LTD / FRACTIONAL CTO</span>
    <span class="bar-cell hide-on-mobile">LON · GMT+0</span>
    <span class="bar-cell hide-on-mobile">REV {buildId}</span>
    <ThemeToggle />
  </div>

  <div class="brand-row">
    <a href="/" class="brand-link" aria-label="Cuko Ltd — home">
      <div class="brand mono" aria-hidden="true">
        <span class="brand-name">Cuko</span><span class="brand-cursor">_</span>
      </div>
      <div class="tagline mono">Cuko Ltd · Fractional Hands-on CTO</div>
    </a>
  </div>

  <nav aria-label="Primary" class="primary-nav">
    <ul>
      {navItems.map(({ href, label, code }) => {
        const normalised = href.replace(/\/$/, '') || '/';
        const isCurrent = normalised === currentPath;
        return (
          <li>
            <a
              href={href}
              aria-current={isCurrent ? 'page' : undefined}
              class:list={['nav-link', { 'is-current': isCurrent }]}
            >
              <span class="nav-code">{code}</span>
              <span class="nav-label">{label}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>

<script>
  function updateNavCurrent() {
    const path = window.location.pathname.replace(/\/$/, '') || '/';
    const links = document.querySelectorAll<HTMLAnchorElement>(
      'header.masthead nav a.nav-link',
    );
    links.forEach((a) => {
      const href = a.pathname.replace(/\/$/, '') || '/';
      const isCurrent = href === path;
      a.classList.toggle('is-current', isCurrent);
      if (isCurrent) {
        a.setAttribute('aria-current', 'page');
      } else {
        a.removeAttribute('aria-current');
      }
    });
  }

  document.addEventListener('astro:page-load', updateNavCurrent);
</script>

<style>
  .masthead {
    margin-bottom: 2rem;
  }

  .bar {
    display: flex;
    align-items: stretch;
    border: 2px solid var(--rule);
    background: var(--paper-alt);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    margin-bottom: 1.4rem;
  }

  .bar-cell {
    padding: 0.4rem 0.8rem;
    border-right: 2px solid var(--rule);
    flex: 1;
    white-space: nowrap;
    display: flex;
    align-items: center;
  }

  .bar-cell:first-child {
    flex: 2;
  }

  @media (max-width: 540px) {
    .hide-on-mobile { display: none; }
  }

  .brand-link {
    text-decoration: none;
    color: inherit;
    display: inline-block;
  }

  .brand-link:hover .brand-name { color: var(--accent); }

  .brand {
    font-weight: 600;
    font-size: 2rem;
    letter-spacing: -0.04em;
    color: var(--ink);
    line-height: 1;
    display: inline-flex;
    align-items: baseline;
  }

  .brand-name {
    transition: color 0.18s ease;
  }

  .brand-cursor {
    color: var(--accent);
    margin-left: 0.05em;
    animation: brand-blink 1.06s steps(1) infinite;
  }

  @keyframes brand-blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-cursor { animation: none; opacity: 1; }
  }

  .tagline {
    font-size: 0.78rem;
    color: var(--ink-soft);
    margin-top: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .primary-nav {
    margin-top: 1.5rem;
    border-top: 2px solid var(--rule);
    border-bottom: 2px solid var(--rule);
  }

  .primary-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
  }

  .primary-nav li {
    flex: 1;
    border-right: 2px solid var(--rule);
    min-width: 6rem;
  }

  .primary-nav li:last-child {
    border-right: none;
  }

  .nav-link {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.7rem 0.9rem;
    color: var(--ink-muted);
    text-decoration: none;
    text-transform: uppercase;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    transition: background 0.18s ease, color 0.18s ease;
    background: var(--paper);
  }

  .nav-link:hover {
    background: var(--ink);
    color: var(--paper);
  }

  .nav-link.is-current {
    background: var(--accent);
    color: var(--accent-ink);
    font-weight: 600;
  }

  .nav-link.is-current:hover {
    background: var(--accent);
    color: var(--accent-ink);
  }

  .nav-code {
    font-size: 0.65rem;
    opacity: 0.6;
    font-weight: 500;
  }

  @media (max-width: 540px) {
    .primary-nav ul { flex-direction: column; }
    .primary-nav li {
      border-right: none;
      border-bottom: 2px solid var(--rule);
      min-width: 0;
    }
    .primary-nav li:last-child { border-bottom: none; }
  }
</style>
