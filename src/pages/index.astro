---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_URL, breadcrumbSchema, webPageSchema } from '../lib/seo';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' });

const title = 'Samuel Ventimiglia — personal site';
const description =
  'Personal site of Samuel Ventimiglia. CTO at Campsor Capital, based in London. Writing on engineering, regulation, and real-time systems.';

const pageSchemas = [
  webPageSchema({
    name: title,
    description,
    url: SITE_URL,
  }),
  breadcrumbSchema([{ name: 'Home', url: SITE_URL }]),
];
---

<BaseLayout title={title} description={description} structuredData={pageSchemas}>

  <section class="hero no-rule">
    <span class="accent-rule" aria-hidden="true"></span>
    <h1 class="reveal delay-1">
      Samuel Ventimiglia.
    </h1>
    <p class="hero-sub mono reveal delay-1-5">
      <strong>CTO at Campsor Capital.</strong> London. Engineering, regulation, real-time systems.
    </p>
    <p class="reveal delay-2">
      This is my personal site. I write here occasionally about the engineering work I find interesting — latency regimes, regulated systems under DORA, MiCA, the EU AI Act, and the practical edges of AI infrastructure.
    </p>
    <p class="reveal delay-3">
      Day job: Chief Technology Officer at <strong class="emphasis">Campsor Capital</strong>. Seventeen years of senior engineering work across crypto-native finance, healthcare, AI infrastructure, and cloud-native systems before that.
    </p>
  </section>

  {recentPosts.length > 0 && (
    <section id="writing">
      <span class="section-label">→ Writing</span>
      <h2>Recent essays</h2>
      <ul class="post-preview">
        {recentPosts.map((post) => (
          <li>
            <time class="post-preview-date mono" datetime={post.data.pubDate.toISOString()}>
              {formatDate(post.data.pubDate)}
            </time>
            <a class="post-preview-link" href={`/blog/${post.id}`}>
              <span class="post-preview-title" transition:name={`post-title-${post.id}`}>{post.data.title}</span>
              <span class="post-preview-desc">{post.data.description}</span>
            </a>
          </li>
        ))}
      </ul>
      <p class="cadence-note">
        <a href="/blog" class="arrow-link">All essays →</a>
      </p>
    </section>
  )}

  <section id="contact-cta">
    <span class="section-label">→ Get in touch</span>
    <h2>Say hello</h2>
    <p>Email is the fastest channel.</p>
    <div class="contact-card">
      <p><span class="label">Email</span> <a href="mailto:samuel@cuko.uk">samuel@cuko.uk</a></p>
      <p><span class="label">LinkedIn</span> <a href="https://www.linkedin.com/in/ventimigliasamuel/" rel="me">linkedin.com/in/ventimigliasamuel</a></p>
      <p><span class="label">GitHub</span> <a href="https://github.com/Cuko-ltd">github.com/Cuko-ltd</a></p>
    </div>
  </section>

</BaseLayout>
