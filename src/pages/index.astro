---
import BaseLayout from '../layouts/BaseLayout.astro';
import NumberCounter from '../components/NumberCounter.astro';
import { SITE_URL, SERVICES, breadcrumbSchema, webPageSchema } from '../lib/seo';

const title = 'Cuko Ltd — Fractional Hands-On CTO for Crypto, Healthcare, AI & Cloud';
const description =
  'Samuel Ventimiglia operates as a fractional, hands-on CTO through Cuko Ltd. Seventeen years of senior engineering leadership, 40+ production launches across crypto-native finance, healthcare, AI infrastructure, and cloud-native architecture.';

const faqItems = [
  {
    question: 'What is a fractional CTO?',
    answer:
      'A fractional Chief Technology Officer is a senior engineering leader engaged on a part-time, ongoing basis — typically one to three days per week — rather than as a full-time hire. The role covers architecture, technical decision-making, hiring, board-level technical communication, and, in hands-on engagements, direct contribution to the codebase.',
  },
  {
    question: 'Which industries do you work with?',
    answer:
      'Cuko Ltd serves four primary sectors: crypto-native finance (funds, OTC desks, exchanges, DeFi protocols), healthcare (clinical platforms and data-sensitive integrations), AI and agent infrastructure (LangChain-based systems and agentic architectures), and cloud-native strategy and implementation (AWS, Google Cloud, Kubernetes, real-time data pipelines).',
  },
  {
    question: 'What is your minimum engagement?',
    answer:
      'One day per week. Engagements run from a single discovery sprint to multi-quarter build leadership. Day-rate, weekly retainer, and monthly retainer options are available.',
  },
  {
    question: 'Are you based in the United Kingdom?',
    answer:
      'Yes. Samuel Ventimiglia is based in London, United Kingdom. Cuko Ltd is registered in England and Wales (Company no. 14989953) with its registered office in West London.',
  },
  {
    question: 'Are you happy to work across different time zones?',
    answer:
      'Yes. Engagements with clients in North America, EMEA, and Asia are routine. Working hours are agreed at engagement start to ensure overlap with the client team.',
  },
  {
    question: 'Do you handle compliance for regulated industries?',
    answer:
      'Yes. Compliance-first system design is one of the core engagement modes. Practical experience covers GDPR, DORA, MiCA, and EU AI Act-aligned architecture, including audit trails, data residency, and incident response. Three production data-breach incidents have been handled end-to-end.',
  },
  {
    question: 'What technology stack do you use?',
    answer:
      'Day-to-day stack: Go, Python, SQL and NoSQL databases, Apache Kafka, NATS JetStream, Nginx, Docker, Kubernetes. Cloud: AWS and Google Cloud. AI tooling: LangChain, TensorFlow. Certifications include AWS and LangChain.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.answer,
    },
  })),
};

const pageSchemas = [
  webPageSchema({
    name: title,
    description,
    url: SITE_URL,
  }),
  breadcrumbSchema([{ name: 'Home', url: SITE_URL }]),
  faqSchema,
];

const featuredServices = SERVICES.slice(0, 4);
---

<BaseLayout title={title} description={description} structuredData={pageSchemas}>

  <section class="hero no-rule">
    <span class="accent-rule" aria-hidden="true"></span>
    <h1 class="reveal delay-1">
      A fractional CTO who <span class="accent">ships code</span>, carries compliance, and aligns engineering with the business.
    </h1>
    <p class="reveal delay-2">
      For crypto-native finance, healthcare, AI infrastructure, and cloud-native scale-ups. Seventeen years of senior engineering leadership across four industries.
    </p>
    <p class="reveal delay-3">
      Recent outcomes: an insurance product taken from a monolithic codebase to <strong class="emphasis">430,000 users</strong> in eight months; a crypto hedge fund moved from spreadsheets to <strong class="emphasis">automated delta hedging</strong> within twelve months.
    </p>
    <p class="reveal delay-4">
      I work alongside your team, not above it. Code lands, decisions get made, the board gets a straight answer.
    </p>
  </section>

  <section id="metrics" class="no-rule">
    <span class="section-label">Track record</span>
    <div class="stat-grid">
      <div class="stat">
        <span class="stat-value"><NumberCounter value={17} /></span>
        <span class="stat-label">Years leading engineering</span>
      </div>
      <div class="stat">
        <span class="stat-value"><NumberCounter value={40} suffix="+" /></span>
        <span class="stat-label">Production launches</span>
      </div>
      <div class="stat">
        <span class="stat-value"><NumberCounter value={4} /></span>
        <span class="stat-label">Industries shipped in</span>
      </div>
      <div class="stat">
        <span class="stat-value"><NumberCounter value={430000} format="comma" /></span>
        <span class="stat-label">Users on a single platform</span>
      </div>
    </div>
  </section>

  <section id="services">
    <span class="section-label">→ What I do</span>
    <h2>Engagement modes</h2>
    <ul class="services">
      {featuredServices.map((svc) => (
        <li>
          <span class="svc-name">{svc.name}</span>
          <span class="svc-desc">{svc.description}</span>
        </li>
      ))}
    </ul>
    <p class="cadence-note">
      <a href="/services" class="arrow-link">See all engagement modes →</a>
    </p>
  </section>

  <section id="audience">
    <span class="section-label">→ Who</span>
    <h2>Who I work with</h2>
    <p>Seed-stage teams without a CTO yet. Series A companies between full-time hires. Later-stage scale-ups bringing in a specialist for a known problem. Enterprises absorbing a new technical capability. The common thread is a technical decision that needs to be right the first time.</p>
    <p>Sectors I know deeply: <strong class="emphasis">crypto-native finance</strong> (funds, OTC desks, exchanges, DeFi protocols), <strong class="emphasis">healthcare</strong> (clinical platforms, data-sensitive integrations), <strong class="emphasis">AI and agent infrastructure</strong> (LangChain-based systems, agentic architectures, integration layers), and <strong class="emphasis">cloud-native strategy and implementation</strong> (AWS, Google Cloud, Kubernetes, real-time data pipelines). Engagements move fastest where two or more of these overlap.</p>
  </section>

  <section id="faq">
    <span class="section-label">→ Questions</span>
    <h2>Frequently asked</h2>
    <dl class="faq">
      {faqItems.map((f) => (
        <>
          <dt>{f.question}</dt>
          <dd>{f.answer}</dd>
        </>
      ))}
    </dl>
  </section>

  <section id="contact-cta">
    <span class="section-label">→ Get in touch</span>
    <h2>Start a conversation</h2>
    <p>Discovery calls run thirty minutes, no obligation. The fastest route is email.</p>
    <div class="contact-card">
      <p><span class="label">Email</span> <a href="mailto:samuel@cuko.uk">samuel@cuko.uk</a></p>
      <p><span class="label">More</span> <a href="/contact" class="arrow-link">All contact channels →</a></p>
    </div>
  </section>

</BaseLayout>
