---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_URL, breadcrumbSchema, webPageSchema } from '../lib/seo';

const title = 'Contact — Samuel Ventimiglia';
const description =
  'Contact channels for Samuel Ventimiglia: email, LinkedIn, GitHub.';

const url = `${SITE_URL}/contact`;

const pageSchemas = [
  webPageSchema({ name: title, description, url }),
  breadcrumbSchema([
    { name: 'Home', url: SITE_URL },
    { name: 'Contact', url },
  ]),
];
---

<BaseLayout title={title} description={description} structuredData={pageSchemas}>

  <section class="hero">
    <h1>Contact</h1>
    <p>Email is the fastest channel. Replies within two working days where possible.</p>
  </section>

  <section id="channels">
    <p class="section-label">Channels</p>
    <h2>How to reach me</h2>
    <div class="contact-card">
      <p><span class="label">Email</span> <a href="mailto:samuel@cuko.uk">samuel@cuko.uk</a></p>
      <p><span class="label">LinkedIn</span> <a href="https://www.linkedin.com/in/ventimigliasamuel/" rel="me">linkedin.com/in/ventimigliasamuel</a></p>
      <p><span class="label">GitHub</span> <a href="https://github.com/Cuko-ltd">github.com/Cuko-ltd</a></p>
    </div>
  </section>

  <section id="about">
    <p class="section-label">About</p>
    <h2>About me</h2>
    <p>I am Chief Technology Officer at Campsor Capital, based in London. This is my personal site — opinions and writing here are my own.</p>
  </section>

</BaseLayout>
