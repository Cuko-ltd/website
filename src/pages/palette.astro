---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_URL } from '../lib/seo';

const title = 'Palette preview — Cuko Ltd (internal)';
const description = 'Internal swatch preview for colour palette decisions.';
const url = `${SITE_URL}/palette`;

interface Swatch {
  name: string;
  value: string;
  hint?: string;
}

interface Palette {
  id: string;
  name: string;
  notes?: string;
  ink: string;
  paper: string;
  paperAlt: string;
  ruleSoft: string;
  accent: string;
  accentInk: string;
}

const currentTokens: Swatch[] = [
  { name: '--ink',        value: '#0a0a0a', hint: 'Text, hard borders' },
  { name: '--ink-muted',  value: '#3a3a3a', hint: 'Body text muted' },
  { name: '--ink-soft',   value: '#6b6b6b', hint: 'Captions, labels' },
  { name: '--paper',      value: '#f4f3ee', hint: 'Background (warm cream)' },
  { name: '--paper-alt',  value: '#e9e8e2', hint: 'Cell fills, code bg' },
  { name: '--rule-soft',  value: '#cfcdc5', hint: 'Inner rules' },
  { name: '--accent',     value: '#ff5b1f', hint: 'Cursor, current-state, hover' },
];

const palettes: Palette[] = [
  {
    id: 'current',
    name: 'A · Current — Warm cream + fluoro orange',
    notes: 'Live now. Brutalist standard. Strong CTA signal.',
    ink: '#0a0a0a', paper: '#f4f3ee', paperAlt: '#e9e8e2', ruleSoft: '#cfcdc5',
    accent: '#ff5b1f', accentInk: '#0a0a0a',
  },
  {
    id: 'yellow',
    name: 'B · Cream + fluoro yellow',
    notes: 'Higher print/zine vibe. Yellow on cream needs ink text on accent fills.',
    ink: '#0a0a0a', paper: '#f4f3ee', paperAlt: '#e9e8e2', ruleSoft: '#cfcdc5',
    accent: '#e5ff00', accentInk: '#0a0a0a',
  },
  {
    id: 'red',
    name: 'C · Cream + hot red',
    notes: 'Italian / terracotta lean. More urgent, less playful.',
    ink: '#0a0a0a', paper: '#f4f3ee', paperAlt: '#e9e8e2', ruleSoft: '#cfcdc5',
    accent: '#e5322a', accentInk: '#f4f3ee',
  },
  {
    id: 'blue',
    name: 'D · Cream + electric blue',
    notes: 'Cooler, more financial-systems feel.',
    ink: '#0a0a0a', paper: '#f4f3ee', paperAlt: '#e9e8e2', ruleSoft: '#cfcdc5',
    accent: '#1f4dff', accentInk: '#f4f3ee',
  },
  {
    id: 'green',
    name: 'E · Cream + signal green',
    notes: 'Crypto / terminal-OK signal. Risks reading as success-state.',
    ink: '#0a0a0a', paper: '#f4f3ee', paperAlt: '#e9e8e2', ruleSoft: '#cfcdc5',
    accent: '#00d96f', accentInk: '#0a0a0a',
  },
  {
    id: 'pure-white',
    name: 'F · Pure white + orange',
    notes: 'Removes warmth. Cleaner, less editorial.',
    ink: '#0a0a0a', paper: '#ffffff', paperAlt: '#f0f0f0', ruleSoft: '#d6d6d6',
    accent: '#ff5b1f', accentInk: '#0a0a0a',
  },
  {
    id: 'slate',
    name: 'G · Cool slate + amber',
    notes: 'Less Italian, more Nordic. Amber retains warmth.',
    ink: '#0d1117', paper: '#eef0f3', paperAlt: '#dde1e6', ruleSoft: '#bcc2c9',
    accent: '#ffb000', accentInk: '#0d1117',
  },
  {
    id: 'terracotta',
    name: 'H · Terracotta + cream',
    notes: 'Italian heritage lean. Warmer overall, accent reads as background-on-fills.',
    ink: '#1a0e08', paper: '#f6ece1', paperAlt: '#ead8c4', ruleSoft: '#c8a784',
    accent: '#c54a1d', accentInk: '#f6ece1',
  },
  {
    id: 'duo',
    name: 'I · Dual accent — orange + cool slate',
    notes: 'Accent for CTA, slate for secondary. Adds layer.',
    ink: '#0a0a0a', paper: '#f4f3ee', paperAlt: '#e9e8e2', ruleSoft: '#cfcdc5',
    accent: '#ff5b1f', accentInk: '#0a0a0a',
  },
];

const componentSamplePalette = (p: Palette) => `
  --ink: ${p.ink}; --paper: ${p.paper}; --paper-alt: ${p.paperAlt};
  --rule: ${p.ink}; --rule-soft: ${p.ruleSoft};
  --accent: ${p.accent}; --accent-ink: ${p.accentInk};
`;
---

<BaseLayout title={title} description={description} noindex={true}>

  <section class="hero no-rule">
    <span class="accent-rule" aria-hidden="true"></span>
    <h1>Palette preview</h1>
    <p>Live swatches and candidate alternates for the cuko.uk colour system. This page is excluded from search and sitemap. Compare candidates against the same component samples (logo, current-nav, button, link, stat).</p>
  </section>

  <section class="no-rule">
    <span class="section-label">→ Current tokens</span>
    <h2>What is shipped now</h2>
    <ul class="swatch-list">
      {currentTokens.map((s) => (
        <li class="swatch-row">
          <span class="swatch-chip" style={`background: ${s.value};`}></span>
          <code class="swatch-name">{s.name}</code>
          <code class="swatch-value">{s.value}</code>
          <span class="swatch-hint">{s.hint}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="no-rule">
    <span class="section-label">→ Candidates</span>
    <h2>Side-by-side comparison</h2>
    <p>Each card uses its own palette tokens locally so the brand cursor, current-nav fill, link colour, and stat values render the way that palette would actually ship.</p>

    <div class="palette-grid">
      {palettes.map((p) => (
        <article class="palette-card" data-id={p.id} style={componentSamplePalette(p)}>
          <header class="palette-card-head">
            <span class="palette-id mono">{p.id}</span>
            <h3 class="palette-name">{p.name}</h3>
            {p.notes && <p class="palette-notes">{p.notes}</p>}
          </header>

          <div class="palette-stripe">
            <span class="stripe-cell" style="background: var(--paper);"></span>
            <span class="stripe-cell" style="background: var(--paper-alt);"></span>
            <span class="stripe-cell" style="background: var(--rule-soft);"></span>
            <span class="stripe-cell" style="background: var(--ink);"></span>
            <span class="stripe-cell" style="background: var(--accent);"></span>
          </div>

          <div class="palette-sample">
            <div class="sample-logo mono">
              Cuko<span class="sample-cursor">_</span>
            </div>

            <div class="sample-nav mono">
              <span class="sample-nav-cell">00 HOME</span>
              <span class="sample-nav-cell sample-nav-current">01 SERVICES</span>
              <span class="sample-nav-cell">02 WORK</span>
            </div>

            <div class="sample-stat">
              <span class="sample-stat-value mono">430,000</span>
              <span class="sample-stat-label mono">Users</span>
            </div>

            <p class="sample-text">
              The board gets a straight answer.
              <a href="#" class="sample-link">All engagement modes →</a>
            </p>

            <div class="sample-tag-row">
              <span class="sample-tag mono"><span class="tag-dot">·</span> Climbing</span>
              <span class="sample-tag mono"><span class="tag-dot">·</span> Harry Potter</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="no-rule">
    <span class="section-label">→ How to choose</span>
    <h2>Decision aid</h2>
    <p>Squint at each card. The accent should read as <em>signal</em>, not decoration: it must hold up when you only see the cursor blink, the current-nav fill, and one link. Pick on those three samples first; the rest follows.</p>
    <p>Tell me a letter (A–I) and any tweaks — accent saturation, paper warmth, dark-mode treatment.</p>
  </section>

<style>
  .swatch-list {
    list-style: none;
    padding: 0;
    margin: 1.4rem 0 0;
    border: 2px solid var(--rule);
  }

  .swatch-row {
    display: grid;
    grid-template-columns: 3rem 10rem 7rem 1fr;
    align-items: center;
    gap: 0.8rem;
    padding: 0.6rem 0.8rem;
    border-bottom: 1px solid var(--rule-soft);
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-size: 0.85rem;
  }

  .swatch-row:last-child { border-bottom: none; }

  .swatch-chip {
    display: block;
    width: 2.4rem;
    height: 1.6rem;
    border: 2px solid var(--rule);
  }

  .swatch-name { color: var(--ink); }
  .swatch-value { color: var(--ink-soft); }
  .swatch-hint { color: var(--ink-muted); font-size: 0.8rem; }

  @media (max-width: 720px) {
    .swatch-row {
      grid-template-columns: 3rem 1fr;
    }
    .swatch-value, .swatch-hint { grid-column: 2; }
  }

  /* ---------- Palette grid ---------- */

  .palette-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    gap: 0;
    border: 2px solid var(--rule);
    margin-top: 1.4rem;
  }

  .palette-card {
    border-right: 2px solid var(--rule);
    border-bottom: 2px solid var(--rule);
    background: var(--paper);
    color: var(--ink);
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .palette-card:last-child { border-right: none; }

  .palette-card-head {
    padding: 1rem 1.2rem 0.8rem;
    border-bottom: 2px solid var(--rule);
    background: var(--paper-alt);
  }

  .palette-id {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-soft);
  }

  .palette-name {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-weight: 500;
    font-size: 0.95rem;
    margin: 0.2rem 0 0.4rem;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .palette-notes {
    margin: 0;
    font-size: 0.78rem;
    color: var(--ink-muted);
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    max-width: none;
  }

  .palette-stripe {
    display: flex;
    height: 2rem;
    border-bottom: 2px solid var(--rule);
  }

  .stripe-cell {
    flex: 1;
    border-right: 1px solid var(--rule);
  }

  .stripe-cell:last-child { border-right: none; }

  .palette-sample {
    padding: 1.1rem 1.2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sample-logo {
    font-weight: 600;
    font-size: 1.6rem;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--ink);
  }

  .sample-cursor {
    color: var(--accent);
  }

  .sample-nav {
    display: flex;
    border: 2px solid var(--ink);
  }

  .sample-nav-cell {
    flex: 1;
    padding: 0.4rem 0.5rem;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink);
    background: var(--paper);
    border-right: 2px solid var(--ink);
    text-align: center;
  }

  .sample-nav-cell:last-child { border-right: none; }

  .sample-nav-current {
    background: var(--accent);
    color: var(--accent-ink);
    font-weight: 600;
  }

  .sample-stat {
    border: 2px solid var(--ink);
    padding: 0.7rem 0.9rem;
    background: var(--paper);
  }

  .sample-stat-value {
    display: block;
    font-size: 2rem;
    line-height: 1;
    font-weight: 500;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  .sample-stat-label {
    display: block;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    margin-top: 0.4rem;
  }

  .sample-text {
    font-family: 'Inter Variable', 'Inter', sans-serif;
    font-size: 0.88rem;
    color: var(--ink-muted);
    margin: 0;
    line-height: 1.5;
    max-width: none;
  }

  .sample-link {
    display: inline-block;
    margin-top: 0.4rem;
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 2px solid var(--ink);
    text-decoration: none;
    padding-bottom: 0.15rem;
  }

  .sample-tag-row {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .sample-tag {
    border: 2px solid var(--ink);
    padding: 0.3rem 0.55rem;
    font-size: 0.72rem;
    color: var(--ink);
    background: var(--paper);
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .tag-dot { color: var(--accent); font-weight: 700; }
</style>
</BaseLayout>
