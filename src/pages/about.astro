---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_URL, breadcrumbSchema, webPageSchema } from '../lib/seo';
import samPortrait from '../assets/sam.jpg';

const title = 'About — Samuel Ventimiglia';
const description =
  'Samuel Ventimiglia — Chief Technology Officer at Campsor Capital, based in London. Seventeen years of senior engineering work across crypto-native finance, healthcare, AI infrastructure, and cloud-native systems.';

const url = `${SITE_URL}/about`;

const pageSchemas = [
  webPageSchema({ name: title, description, url }),
  breadcrumbSchema([
    { name: 'Home', url: SITE_URL },
    { name: 'About', url },
  ]),
];
---

<BaseLayout title={title} description={description} structuredData={pageSchemas}>

  <section class="hero hero-with-portrait">
    <div class="portrait">
      <Image
        src={samPortrait}
        alt="Samuel Ventimiglia"
        widths={[240, 480, 720]}
        sizes="(max-width: 600px) 240px, 320px"
        loading="eager"
        decoding="async"
      />
    </div>
    <div class="hero-text">
      <h1>Samuel Ventimiglia</h1>
      <p>Chief Technology Officer at <strong class="emphasis">Campsor Capital</strong>. Based in London. This page sketches the experience, stack, and operating principles behind the day job and the writing on this site.</p>
    </div>
  </section>

  <style>
    .hero-with-portrait {
      display: grid;
      grid-template-columns: 240px 1fr;
      gap: 2rem;
      align-items: start;
    }
    @media (max-width: 600px) {
      .hero-with-portrait {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
    }
    .portrait {
      width: 100%;
      max-width: 240px;
      aspect-ratio: 1 / 1;
      border: 2px solid var(--rule);
      overflow: hidden;
      background: var(--paper-alt);
    }
    .portrait :global(img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      display: block;
    }
    .hero-text h1 {
      margin-top: 0;
    }
  </style>

  <section id="experience">
    <span class="section-label">→ Experience</span>
    <h2>Seventeen years, four industries</h2>
    <p>Seventeen years of senior engineering work across crypto-native finance, healthcare, AI and agent infrastructure, and cloud-native systems. Forty-plus production systems shipped, four products carried from constrained beta to worldwide scale, and three data-breach incidents handled end-to-end — including regulator engagement and board reporting.</p>
    <p>Currently CTO at Campsor Capital. Prior work spanned greenfield system design, hands-on build leadership, and compliance-aware architecture in regulated environments.</p>
  </section>

  <section id="stack">
    <span class="section-label">→ Stack</span>
    <h2>Day-to-day tooling</h2>
    <dl class="facts">
      <dt>Languages</dt>
      <dd>Go, Python, C++, Node.js, SQL</dd>

      <dt>Data</dt>
      <dd>SQL and NoSQL databases, vector databases (pgvector, Pinecone, Weaviate), Apache Kafka</dd>

      <dt>Infrastructure</dt>
      <dd>Docker, Kubernetes, Nginx, NATS JetStream, Grafana</dd>

      <dt>Cloud</dt>
      <dd>Amazon Web Services (AWS), Google Cloud Platform (GCP), DigitalOcean</dd>

      <dt>AI tooling</dt>
      <dd>Claude, LangChain, TensorFlow</dd>

      <dt>Certifications</dt>
      <dd>AWS, LangChain</dd>

      <dt>Spoken</dt>
      <dd>English, Italian</dd>
    </dl>
  </section>

  <section id="passions">
    <span class="section-label">→ Passions</span>
    <h2>What keeps me curious</h2>
    <p>The work I would do if no-one was paying — and the things that pull me away from the keyboard.</p>
    <ul class="tag-grid" role="list">
      <li class="tag">Agent identity standards</li>
      <li class="tag">Open-source contribution</li>
      <li class="tag">Crypto projects</li>
      <li class="tag">Playing the drums</li>
      <li class="tag">Climbing</li>
      <li class="tag">Skiing</li>
      <li class="tag">Harry Potter</li>
    </ul>
  </section>

  <section id="principles">
    <span class="section-label">→ Operating principles</span>
    <h2>How I work</h2>
    <h3>Code lands</h3>
    <p>I commit code, own infrastructure, and take architectural decisions to closure. Strategy without implementation has never appealed to me.</p>

    <h3>Compliance is shipped, not bolted on</h3>
    <p>For regulated work, audit trails, data residency, and breach posture are designed in on day one — not added under regulator pressure. Three production breach engagements have validated the approach.</p>

    <h3>Straight answers</h3>
    <p>Engineering risk, technical debt, and roadmap trade-offs translated into business terms. Boards know what they are buying and what they are deferring.</p>
  </section>

  <section id="about-site">
    <span class="section-label">→ About this site</span>
    <h2>cuko.uk</h2>
    <p>cuko.uk is my personal site. The domain belongs to Cuko Ltd, a UK company I own; it is not currently used for client work. Writing here is personal — opinions are my own and do not represent Campsor Capital.</p>
  </section>

</BaseLayout>
