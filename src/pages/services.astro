---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_URL, SERVICES, breadcrumbSchema, webPageSchema, faqPageSchema } from '../lib/seo';

const title = 'Fractional CTO Services — Crypto, Healthcare, AI, Cloud | Cuko Ltd';
const description =
  'Eight fractional CTO engagement modes for crypto-native finance, healthcare, AI infrastructure, and cloud-native scale-ups: hands-on build lead, 0→1 architecture, AI integration, compliance-first design, crisis recovery, team scaling, technical due diligence, and advisor.';

const url = `${SITE_URL}/services`;

const faqs = [
  {
    question: 'What is a fractional CTO?',
    answer:
      'A fractional CTO is a senior engineering leader who works with a company part-time on a recurring basis — typically one to three days per week — owning architecture, technology selection, and delivery oversight without taking a permanent full-time role. Fractional CTOs are used by companies that need senior technical judgement before they can justify a full-time hire, or by founders who want a senior second voice on critical decisions.',
  },
  {
    question: 'What is the minimum engagement?',
    answer:
      'One day per week. Anything less and the work does not compound — context-switching cost outweighs delivered value. Build engagements typically run three to six months at one or two days per week; due-diligence engagements are one to four weeks; advisor retainers are ongoing at one day per month with board attendance.',
  },
  {
    question: 'How is pricing structured?',
    answer:
      'Day rate, weekly retainer, or monthly retainer. Pricing depends on engagement mode, sector, and required time zone coverage. Rates and current availability are shared on request after a thirty-minute discovery call.',
  },
  {
    question: 'Which time zones do you cover?',
    answer:
      'Engagements across North America, EMEA, and Asia are routine. Working hours are agreed at engagement start. The base of operation is London, United Kingdom.',
  },
  {
    question: 'What does "hands-on" mean in practice?',
    answer:
      'Hands-on means writing production code alongside the in-house team, owning the hard parts of the codebase, and taking on-call shifts during critical periods — not only producing strategy documents and attending steering meetings. Most Cuko Ltd engagements blend hands-on build work with architecture, hiring, and board-level technical communication.',
  },
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: SERVICES.map((svc, idx) => ({
    '@type': 'ListItem',
    position: idx + 1,
    item: {
      '@type': 'Service',
      name: svc.name,
      description: svc.description,
      provider: {
        '@type': 'Organization',
        name: 'Cuko Ltd',
        url: SITE_URL,
      },
      areaServed: 'Worldwide',
    },
  })),
};

const pageSchemas = [
  webPageSchema({ name: title, description, url }),
  breadcrumbSchema([
    { name: 'Home', url: SITE_URL },
    { name: 'Services', url },
  ]),
  itemListSchema,
  faqPageSchema(faqs),
];
---

<BaseLayout title={title} description={description} structuredData={pageSchemas}>

  <section class="hero">
    <h1>Services</h1>
    <p>A <strong>fractional CTO</strong> is a senior engineering leader who works with a company part-time on a recurring basis — typically one to three days per week — owning architecture, technology selection, and delivery oversight without taking a permanent full-time role. Cuko Ltd offers eight engagement modes, ordered from highest hands-on intensity to advisor-only, for crypto-native finance, healthcare, AI infrastructure, and cloud-native scale-ups.</p>
    <p>Most engagements blend two or three modes; the structure below makes it easier to pick the entry point.</p>
  </section>

  <section id="modes">
    <p class="section-label">Engagement modes</p>
    <h2>How I work</h2>
    <ul class="services">
      {SERVICES.map((svc) => (
        <li>
          <span class="svc-name">{svc.name}</span>
          <span class="svc-desc">{svc.description}</span>
        </li>
      ))}
    </ul>
  </section>

  <section id="compliance-bridge">
    <span class="section-label">→ Compliance</span>
    <h2>Regulation-specific work</h2>
    <p>The compliance-first engagement mode breaks down into four regulatory practice areas: UK and EU GDPR, MiCA, DORA, and the EU AI Act. The <a href="/compliance" class="arrow-link">compliance page →</a> sets out the articles I implement against and the deliverables produced.</p>
  </section>

  <section id="cadence">
    <p class="section-label">Commercials</p>
    <h2>Cadence and commitment</h2>
    <dl class="facts">
      <dt>Minimum</dt>
      <dd>One day per week — anything less and the work does not compound</dd>

      <dt>Pricing</dt>
      <dd>Day rate, weekly retainer, or monthly retainer. Rates and availability on request.</dd>

      <dt>Typical length</dt>
      <dd>Three to six months for build engagements; one to four weeks for due diligence; ongoing for advisor retainers; ongoing once a week for strategy and direction</dd>

      <dt>Time zones</dt>
      <dd>Engagements across North America, EMEA, and Asia are routine. Working hours agreed at engagement start.</dd>

      <dt>Languages</dt>
      <dd>English (native equivalent), Italian (native)</dd>
    </dl>
  </section>

  <section id="faq">
    <p class="section-label">FAQ</p>
    <h2>Frequently asked</h2>
    <dl class="faq">
      {faqs.map((item) => (
        <>
          <dt>{item.question}</dt>
          <dd>{item.answer}</dd>
        </>
      ))}
    </dl>
  </section>

  <section id="next">
    <p class="section-label">Next</p>
    <h2>Start a conversation</h2>
    <p>The fastest path to a sensible engagement is a thirty-minute discovery call. I read every email; expect a reply within two working days.</p>
    <div class="contact-card">
      <p><span class="label">Book</span> <a href="https://calendar.app.google/6cpfUFXXNWYrquBa7" target="_blank" rel="noopener noreferrer" class="arrow-link">Book a discovery call ↗</a></p>
      <p><span class="label">Email</span> <a href="mailto:samuel@cuko.uk">samuel@cuko.uk</a></p>
      <p><span class="label">Channels</span> <a href="/contact">All contact channels →</a></p>
    </div>
  </section>

</BaseLayout>
