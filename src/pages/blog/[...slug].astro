---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollProgress from '../../components/ScrollProgress.astro';
import { SITE_URL, breadcrumbSchema, PERSON, faqPageSchema } from '../../lib/seo';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Auto-compute reading time from raw markdown when not set in frontmatter.
// 220 words per minute is a typical reading pace for technical prose.
const wordCount = post.body?.trim().split(/\s+/).length ?? 0;
const computedMinutes = Math.max(1, Math.ceil(wordCount / 220));
const readingTime = post.data.readingTime ?? `${computedMinutes} min read`;

const url = `${SITE_URL}/blog/${post.id}/`;

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  url,
  image: `${SITE_URL}/og-image.png`,
  author: {
    '@type': 'Person',
    name: post.data.author,
    url: SITE_URL,
    image: PERSON.image,
    jobTitle: PERSON.jobTitle,
    sameAs: PERSON.sameAs,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Cuko Ltd',
    url: SITE_URL,
    logo: {
      '@type': 'ImageObject',
      url: `${SITE_URL}/logo.svg`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': url,
  },
  inLanguage: 'en-GB',
  keywords: post.data.tags.join(', '),
  wordCount,
  timeRequired: `PT${computedMinutes}M`,
};

const pageSchemas = [
  blogPostingSchema,
  breadcrumbSchema([
    { name: 'Home', url: SITE_URL },
    { name: 'Blog', url: `${SITE_URL}/blog/` },
    { name: post.data.title, url },
  ]),
  ...(post.data.faqs && post.data.faqs.length > 0 ? [faqPageSchema(post.data.faqs)] : []),
];

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title={`${post.data.title} — Cuko Ltd`}
  description={post.data.description}
  structuredData={pageSchemas}
  ogType="article"
  article={{
    publishedTime: post.data.pubDate.toISOString(),
    modifiedTime: post.data.updatedDate?.toISOString(),
    author: post.data.author,
    tags: post.data.tags,
  }}
>
  <ScrollProgress />

  <article class="post">
    <header class="post-header">
      <p class="post-meta mono">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        {post.data.updatedDate && (
          <span> · Updated <time datetime={post.data.updatedDate.toISOString()}>{formatDate(post.data.updatedDate)}</time></span>
        )}
        <span> · {readingTime}</span>
      </p>
      <h1>{post.data.title}</h1>
      <p class="post-lede">{post.data.description}</p>
      {post.data.tags.length > 0 && (
        <ul class="post-tags" role="list">
          {post.data.tags.map((tag) => <li class="post-tag mono">{tag}</li>)}
        </ul>
      )}
    </header>

    <div class="post-body">
      <Content />
    </div>

    <footer class="post-footer">
      <p class="post-byline mono">— {post.data.author}, Cuko Ltd</p>
      <div class="contact-card">
        <p><span class="label">Book</span> <a href="https://calendar.app.google/6cpfUFXXNWYrquBa7" target="_blank" rel="noopener noreferrer" class="arrow-link">Book a discovery call ↗</a></p>
        <p><span class="label">Email</span> <a href="mailto:samuel@cuko.uk">samuel@cuko.uk</a></p>
        <p><span class="label">More</span> <a href="/blog" class="arrow-link">All posts →</a></p>
      </div>
    </footer>
  </article>

</BaseLayout>

<style>
  .post {
    margin-bottom: 4rem;
  }

  .post-header {
    border-top: 4px solid var(--accent);
    padding-top: 2rem;
    margin-bottom: 2.5rem;
  }

  .post-meta {
    font-size: 0.8rem;
    color: var(--ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 1.4rem;
  }

  .post-header h1 {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-weight: 500;
    font-size: clamp(1.8rem, 4.4vw, 2.8rem);
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    color: var(--ink);
    max-width: 22ch;
    text-wrap: balance;
  }

  .post-lede {
    font-size: 1.12rem;
    color: var(--ink-muted);
    line-height: 1.5;
    margin: 0 0 1.4rem;
    max-width: 56ch;
  }

  .post-tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .post-tag {
    border: 2px solid var(--rule);
    padding: 0.25rem 0.55rem;
    font-size: 0.72rem;
    color: var(--ink);
    text-transform: lowercase;
    letter-spacing: -0.005em;
  }

  .post-body {
    font-family: 'Inter Variable', 'Inter', sans-serif;
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--ink);
    max-width: 64ch;
  }

  .post-body :global(h2) {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-weight: 500;
    font-size: 1.4rem;
    line-height: 1.25;
    letter-spacing: -0.015em;
    margin: 3rem 0 0.8rem;
    color: var(--ink);
    padding-top: 1rem;
    border-top: 2px solid var(--rule);
  }

  .post-body :global(h3) {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-weight: 500;
    font-size: 1.05rem;
    line-height: 1.3;
    margin: 2rem 0 0.4rem;
    color: var(--ink);
  }

  .post-body :global(p) {
    margin: 0 0 1.1rem;
  }

  .post-body :global(ul), .post-body :global(ol) {
    margin: 0 0 1.1rem;
    padding-left: 1.4rem;
  }

  .post-body :global(li) { margin-bottom: 0.4rem; }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 0.4rem 0 0.4rem 1.2rem;
    margin: 1.4rem 0;
    color: var(--ink-muted);
    font-style: italic;
  }

  .post-body :global(code) {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-size: 0.92em;
    background: var(--paper-alt);
    padding: 0.1em 0.4em;
    border: 1px solid var(--rule-soft);
  }

  .post-body :global(pre) {
    background: var(--paper-alt);
    border: 2px solid var(--rule);
    padding: 1rem 1.2rem;
    overflow-x: auto;
    margin: 1.4rem 0;
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .post-body :global(pre code) {
    background: transparent;
    border: none;
    padding: 0;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 2px solid var(--rule);
    margin: 2.5rem 0;
  }

  .post-body :global(a) {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 3px;
  }

  .post-body :global(a:hover) {
    color: var(--accent);
  }

  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.4rem 0;
    font-size: 0.95rem;
  }

  .post-body :global(th),
  .post-body :global(td) {
    border: 1px solid var(--rule-soft);
    padding: 0.6rem 0.8rem;
    text-align: left;
    vertical-align: top;
  }

  .post-body :global(th) {
    background: var(--paper-alt);
    font-weight: 600;
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .post-footer {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 2px solid var(--rule);
  }

  .post-byline {
    font-size: 0.85rem;
    color: var(--ink-soft);
    margin: 0 0 1.4rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
</style>
