---
import Masthead from '../components/Masthead.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';
import { organizationSchema, personSchema, professionalServiceSchema } from '../lib/seo';
import { ClientRouter } from 'astro:transitions';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  structuredData?: Record<string, unknown>[];
  noindex?: boolean;
}

const { title, description, canonical, structuredData = [], noindex = false } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();

const siteWideSchemas = [organizationSchema(), personSchema(), professionalServiceSchema()];
const allSchemas = [...siteWideSchemas, ...structuredData];
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="color-scheme" content="light dark" />

<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content="Samuel Ventimiglia" />
<meta name="generator" content={Astro.generator} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<link rel="canonical" href={canonicalURL} />
<link rel="alternate" hreflang="en-GB" href={canonicalURL} />
<link rel="alternate" hreflang="x-default" href={canonicalURL} />

<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content="Cuko Ltd" />
<meta property="og:locale" content="en_GB" />

<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />

<link rel="sitemap" href="/sitemap-index.xml" />

<ClientRouter />

{allSchemas.map((schema) => <JsonLd data={schema} />)}

<style is:global>
  :root {
    --ink:        #0a0a0a;
    --ink-muted:  #3a3a3a;
    --ink-soft:   #6b6b6b;
    --paper:      #f4f3ee;
    --paper-alt:  #e9e8e2;
    --rule:       #0a0a0a;
    --rule-soft:  #cfcdc5;
    --accent:     #ff5b1f;
    --accent-ink: #0a0a0a;
    --grid-line:  rgba(10, 10, 10, 0.06);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --ink:        #f4f3ee;
      --ink-muted:  #b8b6ad;
      --ink-soft:   #7d7b73;
      --paper:      #0a0a0a;
      --paper-alt:  #161614;
      --rule:       #f4f3ee;
      --rule-soft:  #2a2a28;
      --accent:     #ff7a3d;
      --accent-ink: #0a0a0a;
      --grid-line:  rgba(244, 243, 238, 0.06);
    }
  }

  * { box-sizing: border-box; }

  ::selection {
    background: var(--accent);
    color: var(--accent-ink);
  }

  html {
    font-size: 16px;
    -webkit-text-size-adjust: 100%;
    scroll-behavior: smooth;
  }

  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  body {
    margin: 0;
    font-family: 'Inter Variable', 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-weight: 400;
    line-height: 1.55;
    color: var(--ink);
    background:
      linear-gradient(var(--grid-line) 1px, transparent 1px) 0 0 / 100% 4rem,
      var(--paper);
    background-attachment: fixed;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-feature-settings: 'ss01' 1, 'cv11' 1;
  }

  /* ---------- Page layout ---------- */

  .page {
    max-width: 64rem;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 4rem;
    position: relative;
  }

  /* ---------- Mono utilities ---------- */

  .mono {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', 'SF Mono', 'Menlo', monospace;
    font-feature-settings: 'tnum' 1, 'lnum' 1;
  }

  /* ---------- Section labels (technical, top-left) ---------- */

  .section-label {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin: 0 0 1rem;
    display: inline-block;
    padding: 0.18rem 0.5rem;
    border: 1px solid var(--rule-soft);
    background: var(--paper-alt);
  }

  /* ---------- Sections ---------- */

  section {
    margin-bottom: 4rem;
    padding-top: 2rem;
    border-top: 2px solid var(--rule);
  }

  section.no-rule {
    border-top: none;
    padding-top: 0;
  }

  section.hero {
    margin-bottom: 5rem;
    padding-top: 3rem;
    padding-bottom: 1rem;
  }

  section:last-of-type {
    margin-bottom: 2rem;
  }

  /* ---------- Hero typography ---------- */

  .hero h1 {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-weight: 500;
    font-size: clamp(2rem, 5.4vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 2rem;
    color: var(--ink);
    max-width: 28ch;
    text-wrap: balance;
  }

  .hero h1 .accent {
    color: var(--accent);
  }

  .hero p {
    font-size: 1.05rem;
    color: var(--ink-muted);
    margin: 0 0 1.1rem;
    max-width: 56ch;
  }

  /* ---------- Standard headings ---------- */

  h2 {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-weight: 500;
    font-size: 1.6rem;
    line-height: 1.18;
    letter-spacing: -0.015em;
    margin: 0 0 1.4rem;
    color: var(--ink);
  }

  h3 {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-weight: 500;
    font-size: 1rem;
    line-height: 1.3;
    margin: 1.6rem 0 0.4rem;
    color: var(--ink);
    letter-spacing: -0.005em;
  }

  section p {
    margin: 0 0 0.9rem;
    max-width: 56ch;
  }

  section p:last-child {
    margin-bottom: 0;
  }

  /* ---------- Links ---------- */

  a {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 0.18s ease, background 0.18s ease;
  }

  a:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  /* ---------- Stat grid (big numerics) ---------- */

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: 0;
    border: 2px solid var(--rule);
    margin: 2rem 0;
  }

  .stat-grid .stat {
    padding: 1.2rem 1.3rem;
    border-right: 2px solid var(--rule);
    border-bottom: 2px solid var(--rule);
  }

  .stat-grid .stat:last-child { border-right: none; }

  @media (max-width: 720px) {
    .stat-grid .stat {
      border-right: none;
      border-bottom: 2px solid var(--rule);
    }
    .stat-grid .stat:last-child { border-bottom: none; }
  }

  .stat-grid .stat-value {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-weight: 500;
    font-size: clamp(2rem, 5vw, 3.2rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--ink);
    display: block;
    margin-bottom: 0.4rem;
    font-variant-numeric: tabular-nums lining-nums;
  }

  .stat-grid .stat-label {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-soft);
  }

  /* ---------- Service list (bordered rows) ---------- */

  ul.services {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    border: 2px solid var(--rule);
  }

  ul.services li {
    padding: 1.1rem 1.3rem;
    border-bottom: 2px solid var(--rule);
    transition: background 0.18s ease;
  }

  ul.services li:last-child { border-bottom: none; }

  ul.services li:hover {
    background: var(--paper-alt);
  }

  ul.services .svc-name {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-weight: 500;
    font-size: 0.96rem;
    color: var(--ink);
    display: block;
    margin-bottom: 0.4rem;
    letter-spacing: -0.005em;
  }

  ul.services .svc-desc {
    color: var(--ink-muted);
    line-height: 1.55;
    font-size: 0.95rem;
    max-width: 56ch;
  }

  /* ---------- Definition list (facts) ---------- */

  dl.facts {
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 0;
    font-size: 0.95rem;
    border: 2px solid var(--rule);
  }

  dl.facts dt {
    color: var(--ink-soft);
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.9rem 1.2rem;
    border-bottom: 1px solid var(--rule-soft);
    border-right: 2px solid var(--rule);
    background: var(--paper-alt);
  }

  dl.facts dd {
    margin: 0;
    color: var(--ink);
    padding: 0.9rem 1.2rem;
    border-bottom: 1px solid var(--rule-soft);
    line-height: 1.5;
  }

  dl.facts dt:nth-last-of-type(1),
  dl.facts dd:last-of-type {
    border-bottom: none;
  }

  @media (max-width: 600px) {
    dl.facts {
      grid-template-columns: 1fr;
    }
    dl.facts dt {
      border-right: none;
      border-bottom: 1px solid var(--rule);
    }
  }

  /* ---------- FAQ ---------- */

  .faq {
    border: 2px solid var(--rule);
    padding: 0;
  }

  .faq dt {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--ink);
    padding: 1.2rem 1.3rem 0.4rem;
    letter-spacing: -0.005em;
    border-top: 1px solid var(--rule-soft);
  }

  .faq dt:first-child {
    border-top: none;
  }

  .faq dd {
    margin: 0;
    color: var(--ink-muted);
    font-size: 0.95rem;
    padding: 0 1.3rem 1.2rem;
    line-height: 1.55;
    max-width: 60ch;
  }

  /* ---------- Contact card ---------- */

  .contact-card {
    background: var(--paper-alt);
    border: 2px solid var(--rule);
    padding: 1.4rem 1.5rem;
    margin-top: 1rem;
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .contact-card p {
    margin: 0 0 0.4rem;
  }

  .contact-card p:last-child {
    margin-bottom: 0;
  }

  .contact-card .label {
    color: var(--ink-soft);
    display: inline-block;
    min-width: 5.5rem;
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
  }

  /* ---------- CTA arrow links ---------- */

  .arrow-link {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    border-bottom: 2px solid var(--ink);
    padding-bottom: 0.2rem;
    color: var(--ink);
    display: inline-block;
    transition: transform 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }

  .arrow-link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
    transform: translateX(4px);
  }

  /* ---------- Cadence note ---------- */

  .cadence-note {
    margin-top: 1.6rem;
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--ink-muted);
  }

  /* ---------- Hero load reveal animation ---------- */

  @keyframes reveal-up {
    from {
      opacity: 0;
      transform: translateY(0.8rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes rule-draw {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  .reveal {
    animation: reveal-up 0.7s cubic-bezier(0.2, 0.8, 0.2, 1) backwards;
  }

  .reveal.delay-1 { animation-delay: 0.05s; }
  .reveal.delay-2 { animation-delay: 0.18s; }
  .reveal.delay-3 { animation-delay: 0.32s; }
  .reveal.delay-4 { animation-delay: 0.46s; }
  .reveal.delay-5 { animation-delay: 0.6s; }

  .accent-rule {
    display: block;
    height: 4px;
    background: var(--accent);
    width: 4rem;
    margin-bottom: 1.4rem;
    transform-origin: left;
    animation: rule-draw 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) backwards;
  }

  /* ---------- Utilities ---------- */

  .emphasis { color: var(--ink); font-weight: 500; }

  code.inline {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-size: 0.9em;
    background: var(--paper-alt);
    padding: 0.1em 0.4em;
    border: 1px solid var(--rule-soft);
  }
</style>
</head>
<body>
  <div class="page">
    <Masthead />
    <main>
      <slot />
    </main>
    <Footer />
  </div>
</body>
</html>
