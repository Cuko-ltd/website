---
import Masthead from '../components/Masthead.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';
import { organizationSchema, personSchema, professionalServiceSchema } from '../lib/seo';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  structuredData?: Record<string, unknown>[];
  noindex?: boolean;
}

const { title, description, canonical, structuredData = [], noindex = false } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();

const siteWideSchemas = [organizationSchema(), personSchema(), professionalServiceSchema()];
const allSchemas = [...siteWideSchemas, ...structuredData];
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="color-scheme" content="light dark" />

<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content="Samuel Ventimiglia" />
<meta name="generator" content={Astro.generator} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<link rel="canonical" href={canonicalURL} />
<link rel="alternate" hreflang="en-GB" href={canonicalURL} />
<link rel="alternate" hreflang="x-default" href={canonicalURL} />

<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content="Cuko Ltd" />
<meta property="og:locale" content="en_GB" />

<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />

<link rel="sitemap" href="/sitemap-index.xml" />

{allSchemas.map((schema) => <JsonLd data={schema} />)}

<style is:global>
  :root {
    --ink:        #1a1a1a;
    --ink-muted:  #4a4a4a;
    --ink-soft:   #6b6b6b;
    --paper:      #fafaf7;
    --paper-alt:  #f2f1ec;
    --rule:       #d9d7d0;
    --accent:     #3b4f8a;
    --accent-dim: #6b7ba8;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --ink:        #ece9e1;
      --ink-muted:  #b6b2a5;
      --ink-soft:   #8a8678;
      --paper:      #141411;
      --paper-alt:  #1c1b17;
      --rule:       #2d2b25;
      --accent:     #9aa8d0;
      --accent-dim: #737fa3;
    }
  }

  * { box-sizing: border-box; }

  html {
    font-size: 17px;
    -webkit-text-size-adjust: 100%;
  }

  body {
    margin: 0;
    font-family: "Charter", "Iowan Old Style", "Georgia", "Times New Roman", serif;
    font-weight: 400;
    line-height: 1.55;
    color: var(--ink);
    background: var(--paper);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .page {
    max-width: 42rem;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 4rem;
  }

  /* ---------- Brand / masthead typography (used by Masthead component) ---------- */

  .brand {
    font-family: "Inter", "SF Pro Text", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.02em;
    color: var(--ink);
  }

  .tagline {
    font-family: "Inter", "SF Pro Text", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.92rem;
    color: var(--ink-soft);
    margin-top: 0.2rem;
  }

  /* ---------- Hero ---------- */

  .hero {
    margin-bottom: 3.5rem;
  }

  .hero h1 {
    font-family: "Charter", "Iowan Old Style", "Georgia", serif;
    font-weight: 400;
    font-size: 2rem;
    line-height: 1.22;
    letter-spacing: -0.01em;
    margin: 0 0 1.25rem;
    color: var(--ink);
  }

  .hero p {
    font-size: 1.12rem;
    color: var(--ink-muted);
    margin: 0 0 1rem;
  }

  /* ---------- Section scaffolding ---------- */

  section {
    margin-bottom: 3rem;
  }

  section:last-of-type {
    margin-bottom: 2rem;
  }

  .section-label {
    font-family: "Inter", "SF Pro Text", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin: 0 0 0.25rem;
  }

  h2 {
    font-family: "Charter", "Iowan Old Style", "Georgia", serif;
    font-weight: 400;
    font-size: 1.4rem;
    line-height: 1.3;
    letter-spacing: -0.005em;
    margin: 0 0 1rem;
    color: var(--ink);
  }

  h3 {
    font-family: "Inter", "SF Pro Text", -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 600;
    font-size: 1.02rem;
    line-height: 1.35;
    margin: 1.4rem 0 0.4rem;
    color: var(--ink);
  }

  section p {
    margin: 0 0 0.9rem;
  }

  section p:last-child {
    margin-bottom: 0;
  }

  /* ---------- Links ---------- */

  a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: color 0.12s;
  }

  a:hover {
    color: var(--ink);
  }

  /* ---------- Service list ---------- */

  ul.services {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: "Inter", "SF Pro Text", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.96rem;
  }

  ul.services li {
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--rule);
  }

  ul.services li:last-child {
    border-bottom: none;
  }

  ul.services .svc-name {
    font-weight: 600;
    color: var(--ink);
    display: block;
    margin-bottom: 0.25rem;
  }

  ul.services .svc-desc {
    color: var(--ink-muted);
    line-height: 1.55;
  }

  /* ---------- Definition list (facts) ---------- */

  dl.facts {
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 0.4rem 1.2rem;
    font-family: "Inter", "SF Pro Text", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.96rem;
  }

  dl.facts dt {
    color: var(--ink-soft);
    font-weight: 500;
  }

  dl.facts dd {
    margin: 0;
    color: var(--ink);
  }

  dl.facts dd + dt {
    margin-top: 0.4rem;
  }

  @media (max-width: 480px) {
    dl.facts {
      grid-template-columns: 1fr;
      gap: 0 0;
    }
    dl.facts dt {
      margin-top: 0.8rem;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    dl.facts dt:first-child {
      margin-top: 0;
    }
    dl.facts dd {
      margin-top: 0.15rem;
    }
  }

  /* ---------- FAQ ---------- */

  .faq dt {
    font-family: "Inter", "SF Pro Text", -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    color: var(--ink);
    margin-top: 1.4rem;
  }

  .faq dt:first-child {
    margin-top: 0;
  }

  .faq dd {
    margin: 0.4rem 0 0;
    color: var(--ink-muted);
    font-size: 1rem;
  }

  /* ---------- Contact block ---------- */

  .contact-card {
    background: var(--paper-alt);
    border: 1px solid var(--rule);
    padding: 1.3rem 1.5rem;
    margin-top: 1rem;
    font-family: "Inter", "SF Pro Text", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.96rem;
    line-height: 1.6;
  }

  .contact-card p {
    margin: 0 0 0.4rem;
  }

  .contact-card p:last-child {
    margin-bottom: 0;
  }

  .contact-card .label {
    color: var(--ink-soft);
    display: inline-block;
    min-width: 4.5rem;
  }

  /* ---------- Cadence note ---------- */

  .cadence-note {
    margin-top: 1.4rem;
    font-family: "Inter", "SF Pro Text", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.96rem;
    color: var(--ink-muted);
  }

  /* ---------- Footer ---------- */

  footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    font-family: "Inter", "SF Pro Text", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.82rem;
    color: var(--ink-soft);
    line-height: 1.6;
  }

  footer p {
    margin: 0 0 0.3rem;
  }

  footer p:last-child {
    margin-bottom: 0;
  }

  /* ---------- Utilities ---------- */

  .emphasis {
    color: var(--ink);
  }

  .center-cta {
    margin-top: 2rem;
    font-family: "Inter", "SF Pro Text", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.96rem;
  }

  code.inline {
    font-family: "SF Mono", "Menlo", "Monaco", "Consolas", monospace;
    font-size: 0.88em;
    background: var(--paper-alt);
    padding: 0.08em 0.32em;
    border-radius: 3px;
  }
</style>
</head>
<body>
  <div class="page">
    <Masthead />
    <main>
      <slot />
    </main>
    <Footer />
  </div>
</body>
</html>
